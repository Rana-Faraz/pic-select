<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PicSelect.Views.ProjectDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Padding="32" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton Click="OnBackClicked" Icon="Back" Label="Back" />
            </CommandBar>

            <StackPanel Grid.Row="1" Spacing="8">
                <TextBlock
                    x:Name="ProjectNameTextBlock"
                    FontSize="30"
                    FontWeight="SemiBold"
                    Text="Project" />
                <TextBlock
                    x:Name="FolderPathTextBlock"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <StackPanel Grid.Row="2" Spacing="12">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Iterations" />

                <Border
                    x:Name="MissingProjectBorder"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="Collapsed">
                    <TextBlock Text="This project could not be loaded." />
                </Border>

                <ListView
                    x:Name="IterationsListView"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold">
                                            <Run Text="Iteration " />
                                            <Run Text="{Binding Number}" />
                                        </TextBlock>
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{Binding TotalPhotoCount}" />
                                            <Run Text=" photos in this round" />
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Spacing="4">
                                        <TextBlock
                                            HorizontalAlignment="Right">
                                            <Run Text="Reviewed " />
                                            <Run Text="{Binding ReviewedPhotoCount}" />
                                        </TextBlock>
                                        <TextBlock
                                            HorizontalAlignment="Right">
                                            <Run Text="Chosen " />
                                            <Run Text="{Binding ChosenPhotoCount}" />
                                        </TextBlock>
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Right">
                                            <Run Text="Ignored " />
                                            <Run Text="{Binding IgnoredPhotoCount}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>
    </Page.Content>
</Page>

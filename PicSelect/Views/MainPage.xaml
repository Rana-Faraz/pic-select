<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PicSelect.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Padding="32" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="12">
                <TextBlock
                    FontSize="32"
                    FontWeight="SemiBold"
                    Text="PicSelect" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Create a non-destructive project from a photo folder and track whether its snapshot is ready for review." />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Orientation="Horizontal"
                Spacing="12">
                <Button
                    x:Name="CreateProjectButton"
                    Click="OnCreateProjectClicked"
                    Content="Create Project From Folder"
                    Style="{StaticResource AccentButtonStyle}" />
                <ProgressRing
                    x:Name="ImportProgressRing"
                    Height="24"
                    IsActive="False"
                    Width="24" />
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                x:Name="StatusTextBlock"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Choose a folder to create your first project." />

            <Grid Grid.Row="3">
                <Border
                    x:Name="EmptyStateBorder"
                    Padding="28"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="No projects yet" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Import a top-level photo folder to create a saved PicSelect project." />
                    </StackPanel>
                </Border>

                <ListView
                    x:Name="ProjectsListView"
                    IsItemClickEnabled="True"
                    ItemClick="OnProjectInvoked"
                    SelectionMode="None"
                    Visibility="Collapsed">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,12"
                                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Text="{Binding DisplayName}" />
                                        <TextBlock
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}">
                                            <Run Text="Status: " />
                                            <Run Text="{Binding ImportStatus}" />
                                        </TextBlock>
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding FolderPath}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Spacing="4">
                                        <TextBlock
                                            HorizontalAlignment="Right">
                                            <Run Text="{Binding PhotoCount}" />
                                            <Run Text=" photos" />
                                        </TextBlock>
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            HorizontalAlignment="Right">
                                            <Run Text="{Binding IterationCount}" />
                                            <Run Text=" iterations" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Page.Content>
</Page>

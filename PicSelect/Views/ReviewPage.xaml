<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PicSelect.Views.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton Click="OnBackClicked" Icon="Back" Label="Back" />
                <AppBarButton Click="OnUndoClicked" Icon="Undo" Label="Undo" />
                <AppBarButton Click="OnPromoteClicked" Icon="Add" Label="Promote" />
                <AppBarButton Click="OnRemoveLaterClicked" Icon="Remove" Label="Remove Later" />
            </CommandBar>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="FileNameTextBlock"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Text="Photo" />
                    <TextBlock
                        x:Name="ProgressTextBlock"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="0 of 0 reviewed" />
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    x:Name="DecisionTextBlock"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center" />
            </Grid>

            <Border
                Grid.Row="2"
                CornerRadius="16"
                Background="#101214"
                Padding="16">
                <Grid>
                    <Image
                        x:Name="PhotoImage"
                        HorizontalAlignment="Stretch"
                        Stretch="Uniform"
                        VerticalAlignment="Stretch" />

                    <TextBlock
                        x:Name="EmptyImageTextBlock"
                        HorizontalAlignment="Center"
                        Foreground="White"
                        Text="No photo selected"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
                </Grid>
            </Border>

            <Grid Grid.Row="3" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="PreviousButton"
                    Click="OnPreviousClicked"
                    Content="Previous"
                    Grid.Column="0">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Left" />
                    </Button.KeyboardAccelerators>
                </Button>

                <Button
                    x:Name="NextButton"
                    Click="OnNextClicked"
                    Content="Next"
                    Grid.Column="1">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Right" />
                    </Button.KeyboardAccelerators>
                </Button>

                <TextBlock
                    Grid.Column="2"
                    x:Name="ReviewHintTextBlock"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Text="Enter chooses. Esc or Space ignores. Left and Right move."
                    VerticalAlignment="Center" />

                <Button
                    x:Name="ChooseButton"
                    Click="OnChooseClicked"
                    Content="Choose"
                    Grid.Column="3"
                    Style="{StaticResource AccentButtonStyle}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter" />
                    </Button.KeyboardAccelerators>
                </Button>

                <Button
                    x:Name="IgnoreButton"
                    Click="OnIgnoreClicked"
                    Content="Ignore"
                    Grid.Column="4">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Escape" />
                        <KeyboardAccelerator Key="Space" />
                    </Button.KeyboardAccelerators>
                </Button>
            </Grid>
        </Grid>
    </Page.Content>
</Page>
